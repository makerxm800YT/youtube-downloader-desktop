// Add dropdown menu to user chip
function addUserDropdown() {
    const userChip = document.querySelector('.user-chip');
    if (!userChip) return;
    
    const dropdown = document.createElement('div');
    dropdown.className = 'dropdown';
    dropdown.style.position = 'relative';
    
    const dropdownContent = document.createElement('div');
    dropdownContent.className = 'dropdown-content';
    dropdownContent.innerHTML = `
        <a onclick="switchAccount()">🔄 Switch Account</a>
        <a onclick="showInfoModal()">ℹ️ About & Info</a>
        <a onclick="window.open('https://github.com', '_blank')">⭐ Star on GitHub</a>
        <a onclick="checkAppUpdate()">🔄 Check for Updates</a>
    `;
    
    userChip.parentNode.insertBefore(dropdown, userChip);
    dropdown.appendChild(userChip);
    dropdown.appendChild(dropdownContent);
    
    document.querySelectorAll('.dropdown-content a').forEach(link => {
        link.style.cursor = 'pointer';
    });
}

// Save quality preference
function saveQualityPreference() {
    if (!isElectron) return;
    const quality = document.getElementById('sel-quality').value;
    const format = document.getElementById('sel-format').value;
    const mode = document.getElementById('sel-mode').value;
    
    window.electronAPI.saveSettings({
        defaultQuality: quality,
        defaultFormat: format,
        defaultMode: mode
    });
}

// Load quality preference
async function loadQualityPreference() {
    if (!isElectron) return;
    const settings = await window.electronAPI.getSettings();
    if (settings.rememberQuality) {
        if (settings.defaultQuality) document.getElementById('sel-quality').value = settings.defaultQuality;
        if (settings.defaultFormat) document.getElementById('sel-format').value = settings.defaultFormat;
        if (settings.defaultMode) document.getElementById('sel-mode').value = settings.defaultMode;
    }
}

// Modified launchApp to include desktop features
const originalLaunchApp = launchApp;
launchApp = function(user) {
    originalLaunchApp(user);
    if (isElectron) {
        loadDesktopSettings();
        loadQualityPreference();
        addUserDropdown();
        document.getElementById('current-account-email').textContent = user.email;
    }
};

// Add event listeners to save preferences
document.addEventListener('DOMContentLoaded', () => {
    if (isElectron) {
        document.getElementById('sel-quality')?.addEventListener('change', saveQualityPreference);
        document.getElementById('sel-format')?.addEventListener('change', saveQualityPreference);
        document.getElementById('sel-mode')?.addEventListener('change', saveQualityPreference);
        
        // Listen for settings shortcut
        window.electronAPI?.onOpenSettings(() => {
            switchTab('settings');
        });
    }
});
