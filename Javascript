// Add these functions to the existing JavaScript

// Detect if running in Electron
const isElectron = window.electronAPI && window.electronAPI.isElectron;

// Load desktop settings if in Electron
async function loadDesktopSettings() {
    if (!isElectron) return;
    
    document.getElementById('desktop-settings').style.display = 'block';
    
    const settings = await window.electronAPI.getSettings();
    document.getElementById('desktop-download-path').textContent = settings.downloadPath;
    document.getElementById('theme-selector').value = settings.theme || 'dark';
    document.getElementById('remember-settings').checked = settings.rememberQuality !== false;
    document.getElementById('auto-update').checked = settings.autoUpdate !== false;
    
    const version = await window.electronAPI.getAppVersion();
    document.getElementById('app-version').textContent = `v${version}`;
}

async function changeDownloadFolder() {
    if (!isElectron) return;
    const newPath = await window.electronAPI.selectDownloadFolder();
    if (newPath) {
        document.getElementById('desktop-download-path').textContent = newPath;
        toast('Download folder updated!', 'success');
    }
}

function changeTheme() {
    const theme = document.getElementById('theme-selector').value;
    if (theme === 'light') {
        document.body.classList.add('light-theme');
    } else if (theme === 'dark') {
        document.body.classList.remove('light-theme');
    } else if (theme === 'system') {
        const darkMode = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (darkMode) {
            document.body.classList.remove('light-theme');
        } else {
            document.body.classList.add('light-theme');
        }
    }
    
    if (isElectron) {
        window.electronAPI.saveSettings({ theme });
    }
}

function toggleRememberSettings() {
    const remember = document.getElementById('remember-settings').checked;
    if (isElectron) {
        window.electronAPI.saveSettings({ rememberQuality: remember });
    }
}

function toggleAutoUpdate() {
    const autoUpdate = document.getElementById('auto-update').checked;
    if (isElectron) {
        window.electronAPI.saveSettings({ autoUpdate });
    }
}

async function checkAppUpdate() {
    if (!isElectron) {
        window.open('https://github.com/yourrepo/youtube-downloader/releases', '_blank');
        return;
    }
    await window.electronAPI.openExternal('https://github.com/yourrepo/youtube-downloader/releases');
    toast('Check GitHub for updates', 'info');
}

function switchAccount() {
    if (confirm('Switch to a different account? You will need to sign in again.')) {
        signOut();
        setTimeout(() => {
            document.getElementById('login-screen').style.display = 'flex';
        }, 100);
    }
}

function logoutAndSwitch() {
    signOut();
    toast('Signed out. You can now log in with a different account.', 'info');
}

